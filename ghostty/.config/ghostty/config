theme = tokyonight
font-size = 14
cursor-style = block
cursor-style-blink = false

macos-option-as-alt = left

# Sets the background opacity (0.0 is fully transparent, 1.0 is fully opaque)
background-opacity = 0.84
# Adds a blur effect to the transparent background (macOS only)
background-blur-radius = 20

# split keybindings
keybind = alt+k=goto_split:top
keybind = alt+j=goto_split:bottom
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right
keybind = alt+left=resize_split:left,24
keybind = alt+down=resize_split:down,24
keybind = alt+up=resize_split:up,24
keybind = alt+right=resize_split:right,24
keybind = cmd+z=toggle_split_zoom

# tab keybindings
#keybind = control+space>comma=move_tab:-1
#keybind = control+space>period=move_tab:1

# quick terminal 
keybind = global:cmd+shift+control+grave_accent=toggle_quick_terminal
